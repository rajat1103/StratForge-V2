generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  avatarUrl     String?
  theme         String   @default("dark")
  preferences   Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  exams         Exam[]
  studySessions StudySession[]
  aiInsights    AIInsight[]
  streak        Streak?
  progressLogs  ProgressLog[]

  @@map("users")
}

model Exam {
  id             String   @id @default(cuid())
  userId         String
  title          String
  type           String   @default("competitive") // competitive | university | certification | skill
  examDate       DateTime?
  description    String?
  totalTopics    Int      @default(0)
  completionPct  Float    @default(0)
  status         String   @default("active") // active | completed | paused
  theme          String   @default("default") // engineering | medical | finance | programming | minimal
  colorAccent    String   @default("#00D4FF")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics         Topic[]
  studyPlans     StudyPlan[]

  @@map("exams")
}

model Topic {
  id             String   @id @default(cuid())
  examId         String
  title          String
  description    String?
  difficulty     Int      @default(3) // 1-5
  priority       Int      @default(3) // 1-5
  estimatedDays  Int      @default(3)
  masteryLevel   Float    @default(0) // 0.0-1.0
  status         String   @default("not_started") // not_started | in_progress | completed | needs_revision
  order          Int      @default(0)
  tags           String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]
  progressLogs   ProgressLog[]
  planTasks      PlanTask[]
  studySessions  StudySession[]

  @@map("topics")
}

model ChecklistItem {
  id          String    @id @default(cuid())
  topicId     String
  label       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)

  topic       Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

model ProgressLog {
  id           String   @id @default(cuid())
  topicId      String
  userId       String
  score        Float    @default(0) // 0-100 self-assessed confidence
  minutesSpent Int      @default(0)
  logDate      DateTime @default(now())
  notes        String?
  sessionType  String   @default("study") // study | revision | practice

  topic        Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("progress_logs")
}

model StudyPlan {
  id           String   @id @default(cuid())
  examId       String
  schedule     Json     // full generated schedule object
  generatedAt  DateTime @default(now())
  validUntil   DateTime?
  version      Int      @default(1)
  isActive     Boolean  @default(true)

  exam         Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  tasks        PlanTask[]

  @@map("study_plans")
}

model PlanTask {
  id            String   @id @default(cuid())
  planId        String
  topicId       String
  scheduledDate DateTime
  durationMins  Int      @default(60)
  completed     Boolean  @default(false)
  taskType      String   @default("study") // study | revision | practice | milestone
  completedAt   DateTime?

  plan          StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  topic         Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("plan_tasks")
}

model StudySession {
  id          String   @id @default(cuid())
  userId      String
  topicId     String?
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  durationMins Int?
  focusScore  Int?     // 1-10 self-rated
  mode        String   @default("normal") // normal | pomodoro | deep_work | revision
  notes       String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic       Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@map("study_sessions")
}

model AIInsight {
  id            String   @id @default(cuid())
  userId        String
  insightType   String   // weak_topic | schedule_suggestion | weekly_report | motivation | prediction
  title         String
  content       String
  payload       Json     @default("{}")
  read          Boolean  @default(false)
  priority      Int      @default(2) // 1=high, 2=medium, 3=low
  generatedAt   DateTime @default(now())
  expiresAt     DateTime?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_insights")
}

model Streak {
  id              String   @id @default(cuid())
  userId          String   @unique
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActiveDate  DateTime?
  totalStudyDays  Int      @default(0)
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}
